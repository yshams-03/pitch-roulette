SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Register free at https://www.football-data.org/client/register
FOOTBALL_DATA_API_KEY=your-football-data-api-key
FOOTBALL_DATA_BASE_URL=https://api.football-data.org/v4

SPORTS_COMPETITION=WC
SPORTS_COMPETITION_CODE=WC
SPORTS_SEASON=2026
MOCK_MODE=false
# Set MOCK_MODE=true for local dev/E2E — serves cached standings/fixtures only
DEMO_MODE=true
DEFAULT_BOT_DIFFICULTY=medium
MAX_BOTS_PER_ROOM=10
FRONTEND_URL=http://localhost:5173
STAGING_FRONTEND_URL=

# Environment label (development | staging | production)
ENVIRONMENT=development

# Optional — error tracking
SENTRY_DSN=
SENTRY_TRACES_SAMPLE_RATE=0.1

# Feature kill switches (true = enabled)
FEATURE_SABOTAGE=true
FEATURE_DRAFT=true
FEATURE_SIDES=true
FEATURE_FLASH_BETS=true

# ESPN public API (no key) — live match events for flash bets
ESPN_ENABLED=true
ESPN_SSL_VERIFY=true
ESPN_LEAGUE_SLUG=fifa.world
ESPN_BASE_URL=https://site.api.espn.com
